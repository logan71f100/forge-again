+void llama_model::gpu_sleep() {
+    if (pimpl->sleeping) {
+        return;
+    }
+    // resize (not assign) so pinned staging buffers persist across juggle cycles
+    pimpl->hib.resize(pimpl->ctxs_bufs.size());
+    for (size_t i = 0; i < pimpl->ctxs_bufs.size(); i++) {
+        auto & ctx  = pimpl->ctxs_bufs[i].first;
+        auto & bufs = pimpl->ctxs_bufs[i].second;
+        if (bufs.empty() || ggml_backend_buffer_is_host(bufs[0].get())) {
+            continue; // host (mmap/CPU) buffers stay resident
+        }
+        const ggml_backend_buffer_type_t buft = ggml_backend_buffer_get_type(bufs[0].get());
+        if (llama_hib_save(ctx.get(), buft, pimpl->hib[i])) {
+            bufs.clear();                 // release VRAM (unique_ptr frees the buffers)
+            llama_hib_reset(ctx.get());   // null tensor->data/->buffer for re-alloc
+        }
+    }
+    pimpl->sleeping = true;
+}
+
+void llama_model::gpu_wake() {
+    if (!pimpl->sleeping) {
+        return;
+    }
+    for (size_t i = 0; i < pimpl->ctxs_bufs.size(); i++) {
+        if (i >= pimpl->hib.size() || pimpl->hib[i].buft == nullptr) {
+            continue; // was not hibernated
+        }
+        auto & ctx  = pimpl->ctxs_bufs[i].first;
+        auto & bufs = pimpl->ctxs_bufs[i].second;
+        ggml_backend_buffer_t buf = llama_hib_restore(ctx.get(), pimpl->hib[i]);
+        if (buf != nullptr) {
+            bufs.emplace_back(buf);       // model owns the buffer again
+        }
+    }
+    // note: hib entries keep their pinned staging buffers for the next sleep
+    pimpl->sleeping = false;
+}
