+void llama_context::gpu_sleep() {
+    synchronize();
+
+    // free scratch compute buffers (recreated on wake via sched_reserve)
+    sched.reset();
+    gf_res_prev.reset();
+    gf_res_reserve.reset();
+    sched_need_reserve = true;
+
+    // free the host output buffer (re-reserved on wake)
+    buf_output.reset();
+
+    // hibernate KV cache device buffers to host RAM
+    if (memory) {
+        memory->gpu_sleep();
+    }
+
+    // hibernate model weight device buffers to host RAM
+    const_cast<llama_model &>(model).gpu_sleep();
+
+    LLAMA_LOG_INFO("%s: GPU asleep (VRAM released)\n", __func__);
+}
+
+void llama_context::gpu_wake() {
+    // restore weights first, then KV, so sched reserve sees a live memory module
+    const_cast<llama_model &>(model).gpu_wake();
+
+    if (memory) {
+        memory->gpu_wake();
+    }
+
+    // recreate scratch compute buffers and the output buffer
+    sched_need_reserve = true;
+    sched_reserve();
+    output_reserve(cparams.n_seq_max);
+
+    LLAMA_LOG_INFO("%s: GPU awake (VRAM reclaimed)\n", __func__);
+}
