diff --git a/src/llama-hibernate.cpp b/src/llama-hibernate.cpp
new file mode 100644
index 0000000..67a92d5
--- /dev/null
+++ b/src/llama-hibernate.cpp
@@ -0,0 +1,88 @@
+#include "llama-hibernate.h"
+
+#include "llama-impl.h"
+
+static size_t llama_hib_total_bytes(ggml_context * ctx) {
+    size_t total = 0;
+    for (ggml_tensor * t = ggml_get_first_tensor(ctx); t != nullptr; t = ggml_get_next_tensor(ctx, t)) {
+        if (t->view_src == nullptr && t->data != nullptr) {
+            total += ggml_nbytes(t);
+        }
+    }
+    return total;
+}
+
+bool llama_hib_save(ggml_context * ctx, ggml_backend_buffer_type_t buft, llama_hib_ctx & h) {
+    const size_t total = llama_hib_total_bytes(ctx);
+    if (total == 0) {
+        h.buft = nullptr;
+        return false;
+    }
+
+    // stage into pinned host memory when possible: the GPU can DMA from/to it
+    // at full PCIe bandwidth, roughly 2x faster than pageable memory.
+    // reuse a previously allocated pinned buffer across sleep/wake cycles.
+    uint8_t * dst = nullptr;
+    if (h.host_buf && ggml_backend_buffer_get_size(h.host_buf.get()) >= total) {
+        dst = (uint8_t *) ggml_backend_buffer_get_base(h.host_buf.get());
+    } else {
+        h.host_buf.reset();
+        ggml_backend_dev_t dev = ggml_backend_buft_get_device(buft);
+        ggml_backend_buffer_type_t hbuft = dev ? ggml_backend_dev_host_buffer_type(dev) : nullptr;
+        if (hbuft != nullptr) {
+            h.host_buf.reset(ggml_backend_buft_alloc_buffer(hbuft, total));
+            if (h.host_buf) {
+                dst = (uint8_t *) ggml_backend_buffer_get_base(h.host_buf.get());
+            } else {
+                LLAMA_LOG_WARN("%s: pinned staging alloc of %.2f MiB failed, using pageable memory\n",
+                        __func__, total / 1024.0 / 1024.0);
+            }
+        }
+    }
+    if (dst == nullptr) {
+        h.blob.resize(total);
+        dst = h.blob.data();
+    }
+
+    h.buft = buft;
+    size_t off = 0;
+    for (ggml_tensor * t = ggml_get_first_tensor(ctx); t != nullptr; t = ggml_get_next_tensor(ctx, t)) {
+        if (t->view_src == nullptr && t->data != nullptr) {
+            const size_t nb = ggml_nbytes(t);
+            ggml_backend_tensor_get(t, dst + off, 0, nb);
+            off += nb;
+        }
+    }
+    return true;
+}
+
+void llama_hib_reset(ggml_context * ctx) {
+    for (ggml_tensor * t = ggml_get_first_tensor(ctx); t != nullptr; t = ggml_get_next_tensor(ctx, t)) {
+        t->data   = nullptr;
+        t->buffer = nullptr;
+    }
+}
+
+ggml_backend_buffer_t llama_hib_restore(ggml_context * ctx, llama_hib_ctx & h) {
+    // allocator requires the context to be in no_alloc mode
+    ggml_set_no_alloc(ctx, true);
+
+    ggml_backend_buffer_t buf = ggml_backend_alloc_ctx_tensors_from_buft(ctx, h.buft);
+    if (buf == nullptr) {
+        return nullptr;
+    }
+
+    const uint8_t * src = h.data();
+    size_t off = 0;
+    for (ggml_tensor * t = ggml_get_first_tensor(ctx); t != nullptr; t = ggml_get_next_tensor(ctx, t)) {
+        if (t->view_src == nullptr && t->data != nullptr) {
+            const size_t nb = ggml_nbytes(t);
+            ggml_backend_tensor_set(t, src + off, 0, nb);
+            off += nb;
+        }
+    }
+
+    // keep host_buf (pinned) allocated for the next sleep; just mark not-hibernated
+    h.buft = nullptr;
+    return buf;
+}
diff --git a/src/llama-hibernate.h b/src/llama-hibernate.h
new file mode 100644
index 0000000..bca8b12
--- /dev/null
+++ b/src/llama-hibernate.h
@@ -0,0 +1,44 @@
+#pragma once
+
+// GPU sleep/wake: move a ggml_context's device tensors out to host RAM and back,
+// freeing/reclaiming VRAM without destroying the context (so KV state survives).
+// Added for the Forge AI Assistant VRAM-juggle use case.
+//
+// The host copy lives in a PINNED (page-locked) buffer so the GPU can DMA at
+// full PCIe bandwidth. The pinned buffer is allocated on the first sleep and
+// kept across sleep/wake cycles, so repeat juggles pay only the copy cost.
+// Falls back to pageable memory if pinned allocation is unavailable/fails.
+
+#include "ggml.h"
+#include "ggml-alloc.h"
+#include "ggml-backend.h"
+#include "ggml-cpp.h"
+
+#include <vector>
+#include <cstdint>
+
+// saved host copy of one ggml_context's device tensor data
+struct llama_hib_ctx {
+    ggml_backend_buffer_type_t buft = nullptr;   // non-null => this ctx is currently hibernated
+
+    ggml_backend_buffer_ptr host_buf;            // pinned staging (preferred, persists across cycles)
+    std::vector<uint8_t>    blob;                // pageable fallback
+
+    uint8_t * data() const {
+        return host_buf ? (uint8_t *) ggml_backend_buffer_get_base(host_buf.get())
+                        : const_cast<uint8_t *>(blob.data());
+    }
+};
+
+// Copy all non-view tensor data of ctx into h's staging memory and record buft.
+// Returns true if there was device data to save. Does NOT free buffers.
+bool llama_hib_save(ggml_context * ctx, ggml_backend_buffer_type_t buft, llama_hib_ctx & h);
+
+// Null every tensor's data/buffer pointer so the allocator will re-allocate them.
+// Call AFTER freeing the ctx's backend buffer(s).
+void llama_hib_reset(ggml_context * ctx);
+
+// Re-allocate the ctx's tensors into a fresh buffer of h.buft and restore the
+// saved data. Returns the new buffer (owned by caller), or nullptr on failure.
+// Clears h.buft but keeps the pinned staging buffer for the next sleep.
+ggml_backend_buffer_t llama_hib_restore(ggml_context * ctx, llama_hib_ctx & h);
diff --git a/src/llama-kv-cache.cpp b/src/llama-kv-cache.cpp
index 680de51..cd3c191 100644
--- a/src/llama-kv-cache.cpp
+++ b/src/llama-kv-cache.cpp
@@ -695,6 +695,46 @@ std::map<ggml_backend_buffer_type_t, size_t> llama_kv_cache::memory_breakdown()
     return ret;
 }
 
+void llama_kv_cache::gpu_sleep() {
+    if (sleeping) {
+        return;
+    }
+    // resize (not assign) so pinned staging buffers persist across juggle cycles
+    hib.resize(ctxs_bufs.size());
+    for (size_t i = 0; i < ctxs_bufs.size(); i++) {
+        auto & ctx = ctxs_bufs[i].first;
+        auto & buf = ctxs_bufs[i].second;
+        if (!buf || ggml_backend_buffer_is_host(buf.get())) {
+            continue;
+        }
+        const ggml_backend_buffer_type_t buft = ggml_backend_buffer_get_type(buf.get());
+        if (llama_hib_save(ctx.get(), buft, hib[i])) {
+            buf.reset();                  // release VRAM
+            llama_hib_reset(ctx.get());
+        }
+    }
+    sleeping = true;
+}
+
+void llama_kv_cache::gpu_wake() {
+    if (!sleeping) {
+        return;
+    }
+    for (size_t i = 0; i < ctxs_bufs.size(); i++) {
+        if (i >= hib.size() || hib[i].buft == nullptr) {
+            continue;
+        }
+        auto & ctx = ctxs_bufs[i].first;
+        auto & buf = ctxs_bufs[i].second;
+        ggml_backend_buffer_t nb = llama_hib_restore(ctx.get(), hib[i]);
+        if (nb != nullptr) {
+            buf.reset(nb);
+        }
+    }
+    // note: hib entries keep their pinned staging buffers for the next sleep
+    sleeping = false;
+}
+
 llama_memory_context_ptr llama_kv_cache::init_batch(
             llama_batch_allocr & balloc,
             uint32_t n_ubatch,
