+def _envdef(key, default):
+    # Default value for a UI slider, overridable per mode-profile via env (set by the forge wrapper menu).
+    try:
+        return type(default)(_os.environ.get(key, default))
+    except Exception:
+        return default
+
+
+def _envchoice(key, default, choices):
+    # Default for a dropdown/radio; uses the env value only if it's a valid choice.
+    v = _os.environ.get(key)
+    return v if v in choices else default
