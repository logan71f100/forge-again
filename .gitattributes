# batch files MUST be CRLF (cmd.exe misparses LF-only: goto/labels break);
# shell scripts MUST be LF (bash rejects CRLF). Pin them regardless of platform.
*.bat text eol=crlf
*.cmd text eol=crlf
*.sh  text eol=lf

# bundled llama-server (patched build with /sleep + /wake) — binary, never text-convert
forge-llm/** binary

# ...except the source patch + its docs, which must stay diffable/reviewable.
# LF-pinned so `git apply` works regardless of the checkout platform.
forge-llm/patches/** text eol=lf diff

# ---------------------------------------------------------------------------
# Release archives.
#
# `export-ignore` keeps these OUT of `git archive` output, which is what
# GitHub serves as "Source code (zip/tar.gz)" on a release. Cloning is
# unaffected -- contributors still get everything.
#
# Rule of thumb: if you don't need it to RUN forge-again, it doesn't belong in
# a release download. Docs, the Docker setup and the llama.cpp patch all stay.
# ---------------------------------------------------------------------------
tests/                  export-ignore
run-tests.bat           export-ignore
.github/                export-ignore
.gitattributes          export-ignore
.gitignore              export-ignore
.git-blame-ignore-revs  export-ignore
CODEOWNERS              export-ignore
.eslintrc.js            export-ignore
.eslintignore           export-ignore
.pylintrc               export-ignore
_typos.toml             export-ignore
package.json            export-ignore
docs/images/social-preview.png export-ignore
