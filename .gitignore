/cache
trace.json
/sysinfo-????-??-??-??-??.json
/test/results.xml
coverage.xml
**/tests/**/expectations

# bundled portable Node runtime for gradio 6 SSR (like venv, not source)
/node/

# self-bootstrap artifacts (portable Python + venv, like venv itself)
/python/
/venv312/
/_venv312_install.log
/_py*.tar.gz
/_pytmp/

# per-machine mode/session state (written by set_mode.py / the mode switch)
/current_mode.txt
/mode_profile.json
/config.json.bak

# secrets -- never commit
/.civitai_token

# server / debug logs
/_v.log
/_v.err.log
*.log

# local launcher leftovers & backups
/run.bat.stock-backup
/Forge.bat
/_run_server.cmd

# per-user extra launch arguments (read by all three start scripts)
/extra-args.txt

# upstream contribution staging (patches + issue drafts, posted manually)
/upstream-patches/

# llama-server's CUDA math libs are reused from the torch install (torch/lib) at
# launch — NVIDIA redistributables, not our code, and each exceeds GitHub's 100MB limit
/forge-llm/cublas64_12.dll
/forge-llm/cublasLt64_12.dll
