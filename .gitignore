# user extensions are folded into this repo as included components (2026-07-22):
#   sd-webui-replacer       (was light-and-ray/sd-webui-replacer @ 91c075f = upstream head)
#   sd-webui-segment-anything (was continue-revolution/... @ 982138c = upstream head, + transformers-5 fix)
#   forge-ai-assistant      (this fork's own extension, code only)
# anything else dropped into extensions/ stays untracked
/extensions/*
!/extensions/put extensions here.txt
!/extensions/sd-webui-replacer/
!/extensions/sd-webui-segment-anything/
!/extensions/forge-ai-assistant/

# assistant runtime state + secrets never enter git (the *.pth rule above keeps
# segment-anything's SAM/GroundingDINO model weights out too)
/extensions/forge-ai-assistant/chat_log.jsonl
/extensions/forge-ai-assistant/ai_memory.json
/extensions/forge-ai-assistant/last_session.json
/extensions/forge-ai-assistant/bot_state.json
/extensions/forge-ai-assistant/ui_profiles.json
/extensions/forge-ai-assistant/live_guidance.txt
/extensions/forge-ai-assistant/takeover_active
/extensions/forge-ai-assistant/anthropic_key.txt
/extensions/forge-ai-assistant/bridge/
/extensions/forge-ai-assistant/kvcache/
/test/stdout.txt
/test/stderr.txt
